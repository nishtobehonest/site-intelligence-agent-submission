# LLM Provider — choose one: anthropic | openai | gemini
LLM_PROVIDER=anthropic

# API keys — only the key for your chosen provider is required
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY = key_here

# Model override — leave blank to use provider default
# Defaults: anthropic=claude-3-5-sonnet-20241022, openai=gpt-4o, gemini=gemini-1.5-pro
LLM_MODEL=

# Vector store and embeddings
CHROMA_PERSIST_DIR=./data/chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retrieval and confidence tuning
TOP_K_RESULTS=5
CONFIDENCE_HIGH_THRESHOLD=0.75
CONFIDENCE_PARTIAL_THRESHOLD=0.50
